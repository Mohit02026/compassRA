{
  "name": "compass",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:debug": "playwright test --debug",
    "e2e:warm": "ts-node --project tsconfig.seed.json tests/e2e/support/warm-fonts.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "ts-node --project tsconfig.seed.json prisma/seed.ts",
    "db:studio": "prisma studio",
    "tunnel": "node scripts/tunnel.js",
    "test:ghl": "node scripts/test-ghl-push.js"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.4",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@prisma/client": "^5.22.0",
    "@react-email/components": "^0.0.26",
    "@react-pdf/renderer": "^4.1.6",
    "@stripe/react-stripe-js": "^6.5.0",
    "@stripe/stripe-js": "^9.7.0",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "googleapis": "^173.0.0",
    "lucide-react": "^0.460.0",
    "next": "14.2.35",
    "next-auth": "^5.0.0-beta.25",
    "prisma": "^5.22.0",
    "react": "^18",
    "react-dom": "^18",
    "resend": "^4.0.0",
    "stripe": "^22.2.0",
    "tailwind-merge": "^2.5.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitest/ui": "^4.1.7",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "dotenv": "^16.0.0",
    "dotenv-cli": "^8.0.0",
    "msw": "^2.14.6",
    "postcss": "^8",
    "tailwindcss": "^4.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.7"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  },
  "pnpm": {
    "packageExtensions": {
      "next@*": {
        "peerDependenciesMeta": {
          "@playwright/test": {
            "optional": true
          }
        }
      }
    }
  }
}
