    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "lucide-react": "^0.460.0",
    "next": "14.2.35",
    "next-auth": "^5.0.0-beta.25",
    "prisma": "^5.22.0",
    "react": "^18",
    "react-dom": "^18",
    "resend": "^4.0.0",
